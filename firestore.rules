rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function email() {
      return request.auth.token.email;
    }

    function isBootstrapAdmin() {
      return isSignedIn() && email() == "habibiarmin27@gmail.com";
    }

    function staffDocExists() {
      return exists(/databases/$(database)/documents/staff/$(email()));
    }

    function staffDoc() {
      return get(/databases/$(database)/documents/staff/$(email())).data;
    }

    function isActive() {
      return isBootstrapAdmin() ||
        (isSignedIn() && staffDocExists() && staffDoc().active != false);
    }

    function isAdmin() {
      return isBootstrapAdmin() ||
        (isActive() && staffDoc().role == "admin");
    }

    match /staff/{staffEmail} {
      allow read: if isActive();
      allow create: if isAdmin() || (isBootstrapAdmin() && staffEmail == email());
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /customers/{customerId} {
      allow read, create, update: if isActive();
      allow delete: if isAdmin();
    }

    match /{path=**}/purchases/{purchaseId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.recordedBy == email());
      allow create: if isActive();
      allow update: if isSignedIn() && (isAdmin() || resource.data.recordedBy == email()) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['amount', 'branch']);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.recordedBy == email());
    }

    match /sales/{saleId} {
      allow read: if isAdmin();
      allow create: if isActive();
      allow update: if isSignedIn() && (isAdmin() || resource.data.recordedBy == email()) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['amount', 'branch']);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.recordedBy == email());
    }

    match /vouchers/{voucherId} {
      allow read, create, update: if isActive();
      allow delete: if false;
    }

    match /activity/{activityId} {
      allow read: if isAdmin();
      allow create: if isActive();
      allow update, delete: if false;
    }

    match /stats/{statId} {
      allow read: if isAdmin();
      allow write: if isActive();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
